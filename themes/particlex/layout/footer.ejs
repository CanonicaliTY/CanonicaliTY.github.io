<footer id="footer">
    <div id="footer-wrap">
        <div>
            &copy;
            <%= theme.footer.since %> - <%= date(Date.now(), "YYYY") %> <%= config.author %>
        </div>
        <div>
            Built with <a href="https://hexo.io">Hexo</a> and a customised
            <a href="https://github.com/theme-particlex/hexo-theme-particlex">ParticleX</a> theme.
        </div>
        <% if (theme.footer.ICP.enable) { %>
        <div>
            ICP registration:
            <% if (theme.footer.ICP.link) { %>
            <a href="<%- url_for(theme.footer.ICP.link) %>"><%= theme.footer.ICP.code %></a>
            <% } else { %>
            <%= theme.footer.ICP.code %>
            <% } %>
        </div>
        <% } %>
    </div>
</footer>
